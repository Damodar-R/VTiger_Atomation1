<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="HybridFrameworkSuite"
       parallel="tests"
       thread-count="3">

   <!-- Listener for reports & screenshots -->
   <listeners>
      <listener class-name="genericUtility.ListenersImplementation"/>
   </listeners> 

  

   <!-- ========== Firefox Execution ========== -->
   <test name="chromeTests">
      <parameter name="browser" value="chrome"/>
      <groups>
      <run>
      <include name="smoke"/>
      </run>
      </groups>
       
      <classes>
         <class name="demoproject.TC_004Practice"/>
         <class name="demoproject.TC_005Practice"/>
         <class name="demoproject.TC_006Practice"/>
        
      </classes>
   </test>

</suite>